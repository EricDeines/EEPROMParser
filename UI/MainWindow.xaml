<Window x:Class="EEPROMParser.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EEPROMParser.UI"
        xmlns:controller="clr-namespace:EEPROMParser.Controller;assembly=Controller"
        mc:Ignorable="d"
        Title="Names" Height="540" Width="960" WindowStartupLocation="CenterScreen">
  <Window.Resources>

  </Window.Resources>

  <Grid ShowGridLines="true">

    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="3*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Menu Grid.Row="0" Grid.ColumnSpan="3">
      <MenuItem Header="Edit">
        <MenuItem Header="Create" />
        <MenuItem Header="Create2" />
        <MenuItem Header="Create3" />
      </MenuItem>
    </Menu>

    <GroupBox Grid.Row="1" Grid.Column="0" Grid.RowSpan="2" Margin="10,10,5,10">
      <GroupBox.Header>
        <Label Content="Speicherbereich" />
      </GroupBox.Header>

      <DockPanel>
        <Rectangle DockPanel.Dock="Left" Width="10"/>
        <Rectangle DockPanel.Dock="Right" Width="10"/>
        <Rectangle DockPanel.Dock="Top" Height="10"/>
        <Rectangle DockPanel.Dock="Bottom" Height="10" />
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Grid.ColumnDefinitions>
            <ColumnDefinition/>
          </Grid.ColumnDefinitions>

          <controller:MyOwnCheckbox Grid.Row="0"
                                    Margin="0,0,0,5"
                                    Text="Alle Bereiche lesen?" 
                                    IsChecked="false"/>

          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding RegionGroups, Mode=OneWay}">
              <ItemsControl.Template>
                <ControlTemplate TargetType="ItemsControl">
                  <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="2">
                    <ItemsPresenter/>
                  </Border>
                </ControlTemplate>
              </ItemsControl.Template>

              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>

              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <controller:MyOwnCheckbox Text="{Binding Path=Text, Mode=TwoWay}"
                                            IsChecked="{Binding Path=IsChecked, Mode=TwoWay}"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>

            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </DockPanel>

    </GroupBox>

    <GroupBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="5,10,10,10">
      <GroupBox.Header>
        <Label Content="Variante"/>
      </GroupBox.Header>
      <Grid ShowGridLines="false">
        <Grid.RowDefinitions>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <DockPanel  Grid.Column="0">
          <Rectangle DockPanel.Dock="Left" Width="10"/>
          <Rectangle DockPanel.Dock="Right" Width="10"/>
          <Rectangle DockPanel.Dock="Top" Height="10"/>
          <Rectangle DockPanel.Dock="Bottom" Height="10" />
          <StackPanel>
            <Label Content="Motor" />
            <ComboBox Name="ComboBox2"
                      Text="My Cities"
                      ItemsSource="{Binding Drives}"
                      SelectedItem="{Binding SelectedDrive, Mode=OneWayToSource}"
                      Margin="5,5,5,5"/>
          </StackPanel>
        </DockPanel>

        <Rectangle Grid.Column="1" VerticalAlignment="Stretch" Width="1" Margin="2" Stroke="Gray"/>
        
        <DockPanel Grid.Column="2">
          <Rectangle DockPanel.Dock="Left" Width="10"/>
          <Rectangle DockPanel.Dock="Right" Width="10"/>
          <Rectangle DockPanel.Dock="Top" Height="10"/>
          <Rectangle DockPanel.Dock="Bottom" Height="10" />
          <StackPanel>
            <Label Content="Firmware" />
            <ComboBox Name="ComboBox3"
                      Text="My Cities"
                      ItemsSource="{Binding Firmwares}"
                      SelectedItem="{Binding SelectedFirmware, Mode=OneWayToSource}"
                      Margin="5,5,5,5"/>
          </StackPanel>
        </DockPanel>

        <Rectangle Grid.Column="3" VerticalAlignment="Stretch" Width="1" Margin="2" Stroke="Gray"/>

        <DockPanel Grid.Column="4">
          <Rectangle DockPanel.Dock="Left" Width="10"/>
          <Rectangle DockPanel.Dock="Right" Width="10"/>
          <Rectangle DockPanel.Dock="Top" Height="10"/>
          <Rectangle DockPanel.Dock="Bottom" Height="10" />
          <StackPanel>
            <Label Content="Kommunikation" />
            <ComboBox Name="ComboBox4"
                      Text="My Cities"
                      ItemsSource="{Binding Comms}"
                      SelectedItem="{Binding SelectedComms, Mode=OneWayToSource}"
                      Margin="5,5,5,5"/>
          </StackPanel>
        </DockPanel>
      </Grid>
    </GroupBox>

    <DockPanel Grid.Row="3" Grid.Column="0">
      <Rectangle DockPanel.Dock="Left" Width="50"/>
      <Rectangle DockPanel.Dock="Right" Width="50"/>
      <Rectangle DockPanel.Dock="Top" Height="10"/>
      <Rectangle DockPanel.Dock="Bottom" Height="10" />
      <Button HorizontalAlignment="Center"
              VerticalAlignment="Center"
              MinWidth="100"
              Content="Click Me" />
    </DockPanel>

    <DockPanel Grid.Row="3" Grid.Column="2">
      <Rectangle DockPanel.Dock="Left" Width="50"/>
      <Rectangle DockPanel.Dock="Right" Width="50"/>
      <Rectangle DockPanel.Dock="Top" Height="10"/>
      <Rectangle DockPanel.Dock="Bottom" Height="10" />
      <Button HorizontalAlignment="Center"
              VerticalAlignment="Center"
              MinWidth="100"
              Content="Check"
              Click="OnClick" />
    </DockPanel>


    <Separator Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"/>

    <Label Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Content="{Binding ValidateResult, Mode=OneWay}" />


  </Grid>
</Window>
